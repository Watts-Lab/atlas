# syntax=docker/dockerfile:1
FROM --platform=linux/amd64 public.ecr.aws/docker/library/python:3.13-slim
WORKDIR /app

# Install only the MCP server's dependencies (not the full backend stack).
COPY atlas_mcp/requirements.txt ./atlas_mcp/requirements.txt
RUN pip install --upgrade pip \
    && pip install -r ./atlas_mcp/requirements.txt \
    && pip install -U 'watchdog[watchmedo]'

# Copy the MCP source.
COPY atlas_mcp ./atlas_mcp

# Run as a non-root user.
RUN adduser --disabled-password --gecos "" mcpuser \
    && chown -R mcpuser:mcpuser /app
USER mcpuser

# MCP_TRANSPORT is pinned to http: this image is the hosted deployment. stdio
# mode is for local installs only and enables reading the local filesystem, so
# it must never be the default for the server container.
ENV PYTHON_ENV=production \
    MCP_TRANSPORT=http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=9000 \
    MCP_PATH=/mcp \
    ATLAS_API_URL=http://backend:8000/api/v1

EXPOSE 9000

# Container-level health check. Uses Python (no curl in the slim image) to hit
# the plain-HTTP /health route the server exposes alongside the MCP endpoint.
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request,os,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:'+os.getenv('MCP_PORT','9000')+'/health', timeout=4).status==200 else 1)" || exit 1

CMD ["python", "-m", "atlas_mcp.server"]
