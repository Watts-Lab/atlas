# Api config
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App config
SOCKET_SECRET=
JWT_SECRET=

# Encryption key for secrets stored at rest (users' bring-your-own OpenAI /
# Anthropic keys). Must be a Fernet key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep it stable — changing it makes previously stored provider keys undecryptable.
ENCRYPTION_KEY=

BASE_URL_DEV=http://localhost:5173
BASE_URL_PROD=https://atlas.seas.upenn.edu

# Database
DB_URI=
DB_NAME=atlas

PYTHONPATH=./server
PYTHONIOENCODING=utf8

# AWS email
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# AWS s3
AWS_S3_BUCKET=
AWS_S3_KEY=
AWS_S3_SECRET=

# WebAuthn / passkey login (all optional — sensible per-environment defaults are
# applied in config/app_config.py). Only set these if Atlas is served from a
# domain other than the defaults below.
#   WEBAUTHN_RP_ID   : registrable domain, NO scheme / NO port
#                      (dev default: localhost, prod default: atlas.seas.upenn.edu)
#   WEBAUTHN_RP_NAME : name shown in the OS passkey prompt (default: Atlas)
#   WEBAUTHN_ORIGIN  : full origin the browser reports (scheme + host + port)
#                      (dev default: http://localhost:5173,
#                       prod default: https://atlas.seas.upenn.edu)
# WEBAUTHN_RP_ID=
# WEBAUTHN_RP_NAME=
# WEBAUTHN_ORIGIN=
