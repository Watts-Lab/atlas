{
  "family": "atlas-orchestration",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "533266983284.dkr.ecr.us-east-1.amazonaws.com/atlas-frontend",
      "cpu": 0,
      "portMappings": [
        {
          "name": "frontend-80-tcp",
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "command": ["/bin/sh -c \"nginx -g 'daemon off;'\""],
      "entryPoint": ["sh", "-c"],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-orchestration",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": [],

      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:80/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    },
    {
      "name": "backend",
      "image": "533266983284.dkr.ecr.us-east-1.amazonaws.com/atlas-backend",
      "cpu": 0,
      "portMappings": [
        {
          "name": "backend-8000-tcp",
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "command": [
        "/bin/sh -c \"WORKER_ID=1 python3 -m sanic api.app --host 0.0.0.0 --port 8000 --workers 1 & WORKER_ID=2 python3 -m sanic api.app --host 0.0.0.0 --port 8001 --workers 1 & WORKER_ID=3 python3 -m sanic api.app --host 0.0.0.0 --port 8002 --workers 1 & wait\""
      ],
      "entryPoint": ["sh", "-c"],
      "essential": true,
      "environment": [
        { "name": "CELERY_BROKER_URL", "value": "redis://127.0.0.1:6379/0" },
        { "name": "CELERY_RESULT_BACKEND", "value": "redis://127.0.0.1:6379/0" }
      ],
      "environmentFiles": [
        { "value": "arn:aws:s3:::atlasenvironment/server.env", "type": "s3" }
      ],
      "dependsOn": [{ "containerName": "redis", "condition": "HEALTHY" }],
      "mountPoints": [
        {
          "sourceVolume": "papers",
          "containerPath": "/app/api/papers",
          "readOnly": false
        }
      ],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-orchestration",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": [],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 90
      }
    },
    {
      "name": "celery",
      "image": "533266983284.dkr.ecr.us-east-1.amazonaws.com/atlas-backend",
      "cpu": 0,
      "portMappings": [],
      "command": [
        "/bin/sh -c \"celery -A workers.celery_config.celery worker --loglevel=info\""
      ],
      "entryPoint": ["sh", "-c"],
      "essential": true,
      "environment": [
        { "name": "CELERY_BROKER_URL", "value": "redis://127.0.0.1:6379/0" },
        {
          "name": "CELERY_RESULT_BACKEND",
          "value": "redis://127.0.0.1:6379/0"
        },
        { "name": "C_FORCE_ROOT", "value": "false" }
      ],
      "environmentFiles": [
        { "value": "arn:aws:s3:::atlasenvironment/server.env", "type": "s3" }
      ],
      "dependsOn": [{ "containerName": "redis", "condition": "HEALTHY" }],
      "mountPoints": [
        {
          "sourceVolume": "papers",
          "containerPath": "/app/api/papers",
          "readOnly": false
        }
      ],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-orchestration",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": [],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "celery -A workers.celery_config.celery inspect ping | grep 'pong' || exit 1"
        ],
        "interval": 60,
        "timeout": 15,
        "retries": 3,
        "startPeriod": 60
      }
    },
    {
      "name": "redis",
      "image": "public.ecr.aws/docker/library/redis:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "redis-6379-tcp",
          "containerPort": 6379,
          "hostPort": 6379,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-orchestration",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": [],

      "healthCheck": {
        "command": ["CMD-SHELL", "redis-cli ping | grep PONG || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    },
    {
      "name": "mcp",
      "image": "533266983284.dkr.ecr.us-east-1.amazonaws.com/atlas-mcp",
      "cpu": 0,
      "portMappings": [
        {
          "name": "mcp-9000-tcp",
          "containerPort": 9000,
          "hostPort": 9000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "command": ["/bin/sh -c \"python -m atlas_mcp.server\""],
      "entryPoint": ["sh", "-c"],
      "essential": false,
      "environment": [
        { "name": "ATLAS_API_URL", "value": "http://localhost:8000/api/v1" },
        { "name": "MCP_TRANSPORT", "value": "http" },
        { "name": "MCP_HOST", "value": "0.0.0.0" },
        { "name": "MCP_PORT", "value": "9000" },
        { "name": "MCP_PATH", "value": "/mcp" }
      ],
      "environmentFiles": [],
      "dependsOn": [{ "containerName": "backend", "condition": "START" }],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-orchestration",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": [],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:9000/health', timeout=4).status==200 else 1)\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ],
  "taskRoleArn": "arn:aws:iam::533266983284:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::533266983284:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [{ "name": "papers", "host": {} }],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
